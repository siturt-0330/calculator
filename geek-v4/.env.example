# ============================================================
# GEEK v4 — Environment Variables
# ============================================================
# このファイルを `.env` にコピーして実際の値を入れてください。
# `.env` は .gitignore で除外されているので commit されません。
#
# EXPO_PUBLIC_* prefix のものはクライアントバンドルに同梱されます。
# 機密度の高いキー (service_role, ANTHROPIC_API_KEY 等) は絶対に
# EXPO_PUBLIC_* に置かないでください。それらは Supabase secrets /
# サーバー側 Edge Function 環境変数で管理します。
# ============================================================

# --- Supabase (必須) ---
# Project Settings → API から取得。anon key は RLS 前提で公開して OK。
EXPO_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- PostHog (任意) ---
# 空のままだと analytics は無効化される。本番は必ず埋める。
EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Sentry (任意) ---
# 空のままだと initSentry() が早期 return して noop。本番は必ず埋める。
EXPO_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# --- Web Push (任意 / Web のみ) ---
# Supabase Edge Function 側で生成した VAPID 公開鍵。Push 購読時に使用。
# 秘密鍵は Supabase secrets (`supabase secrets set VAPID_PRIVATE_KEY=...`) 側へ。
EXPO_PUBLIC_VAPID_PUBLIC_KEY=
