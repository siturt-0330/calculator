{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["deno.window", "deno.ns", "esnext"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  },
  "fmt": {
    "options": {
      "singleQuote": true,
      "lineWidth": 100,
      "indentWidth": 2,
      "semiColons": true
    }
  }
}
